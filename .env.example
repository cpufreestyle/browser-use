# ===========================================
#  AI API 配置
# ===========================================
# 请填入你的真实 API Key
OPENAI_API_KEY=sk-your-key-here

# 使用 StepFun (阶跃星辰) OpenAI 兼容 API:
OPENAI_BASE_URL=https://api.stepfun.com/v1
OPENAI_MODEL=step-1-8k

# 如需切换回 OpenAI 官方, 注释上面两行并取消下面注释:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
